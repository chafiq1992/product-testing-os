import { 
  getFirestore, collection, addDoc, onSnapshot, query, 
  where, doc, setDoc, getDoc, updateDoc, deleteDoc, setLogLevel
} from 'firebase/firestore';
import { 
  getAuth, signInAnonymously, signInWithCustomToken, onAuthStateChanged 
} from 'firebase/auth';

// --- Firebase Configuration ---
const appId = typeof __app_id !== 'undefined' ? __app_id : 'wholesale-dashboard-123';
const firebaseConfig = typeof __firebase_config !== 'undefined' 
  ? JSON.parse(__firebase_config) 
  : { apiKey: "", authDomain: "", projectId: "", storageBucket: "", messagingSenderId: "", appId: "" };

const app = initializeApp(firebaseConfig);
const db = getFirestore(app);
const auth = getAuth(app);
setLogLevel('error');

// --- Constants ---
const SEGMENTS = ['Men', 'Women', 'Kids'];
const SEASONS = ['Winter', 'Summer', 'Spring', 'Fall'];

const API_KEY = ""; // Provided by environment

const App = () => {
  const [user, setUser] = useState(null);
  const [isAuthReady, setIsAuthReady] = useState(false);
  const [activeTab, setActiveTab] = useState('overview');
  const [products, setProducts] = useState([]);
  const [vendorTag, setVendorTag] = useState('');
  
  useEffect(() => {
    const initAuth = async () => {
      try {
        if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
          await signInWithCustomToken(auth, __initial_auth_token);
        } else {
          await signInAnonymously(auth);
        }
      } catch (err) {
        console.error("Auth error:", err);
      }
    };

    onAuthStateChanged(auth, (user) => {
      setUser(user);
      setIsAuthReady(true);
      if (user) {
        setVendorTag(`VND-${user.uid.substring(0, 6).toUpperCase()}`);
      }
    });

    initAuth();
  }, []);

  useEffect(() => {
    if (!isAuthReady || !user) return;

    const q = query(collection(db, `artifacts/${appId}/users/${user.uid}/products`));
    const unsubscribe = onSnapshot(q, (snapshot) => {
      const prods = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
      setProducts(prods);
    });

    return () => unsubscribe();
  }, [isAuthReady, user]);

  const renderContent = () => {
    if (!isAuthReady) return <LoadingScreen />;
    
    switch (activeTab) {
      case 'overview': return <OverviewTab products={products} />;
      case 'inventory': return <InventoryTab products={products} />;
      case 'add-new': return <AddNewTab user={user} vendorTag={vendorTag} setActiveTab={setActiveTab} />;
      case 'settings': return <SettingsTab vendorTag={vendorTag} user={user} />;
      default: return <OverviewTab products={products} />;
    }
  };

  return (
    <div className="flex flex-col md:flex-row h-screen bg-slate-50 font-sans text-slate-900 overflow-hidden">
      {/* Desktop Sidebar */}
      <nav className="hidden md:flex w-64 bg-white border-r border-slate-200 flex-col">
        <div className="p-6 border-b border-slate-100">
          <h1 className="text-xl font-bold bg-gradient-to-r from-blue-600 to-indigo-600 bg-clip-text text-transparent flex items-center gap-2">
            <Package className="text-blue-600" />
            WholesaleHub
          </h1>
          <p className="text-xs text-slate-500 mt-1 uppercase tracking-wider font-semibold">Vendor Portal</p>
        </div>

        <div className="flex-1 p-4 space-y-2">
          <NavItem active={activeTab === 'overview'} onClick={() => setActiveTab('overview')} icon={<LayoutDashboard size={20}/>} label="Overview" />
          <NavItem active={activeTab === 'inventory'} onClick={() => setActiveTab('inventory')} icon={<Package size={20}/>} label="Inventory" />
          <NavItem active={activeTab === 'add-new'} onClick={() => setActiveTab('add-new')} icon={<PlusCircle size={20}/>} label="Add Product" />
        </div>

        <div className="p-4 border-t border-slate-100">
          <NavItem active={activeTab === 'settings'} onClick={() => setActiveTab('settings')} icon={<Settings size={20}/>} label="Profile" />
          <div className="mt-4 p-3 bg-blue-50 rounded-xl">
            <p className="text-[10px] text-blue-600 font-bold uppercase tracking-tight">Vendor Tag</p>
            <p className="text-sm font-mono font-bold text-blue-900">{vendorTag}</p>
          </div>
        </div>
      </nav>

      {/* Main Content Area */}
      <main className="flex-1 overflow-y-auto pb-24 md:pb-8 p-4 md:p-8">
        {renderContent()}
      </main>

      {/* Mobile Bottom Navigation */}
      <nav className="md:hidden fixed bottom-0 left-0 right-0 bg-white border-t border-slate-200 px-6 py-3 flex justify-between items-center z-50 pb-safe shadow-[0_-4px_10px_rgba(0,0,0,0.05)]">
        <MobileNavItem active={activeTab === 'overview'} onClick={() => setActiveTab('overview')} icon={<LayoutDashboard size={24}/>} label="Home" />
        <MobileNavItem active={activeTab === 'inventory'} onClick={() => setActiveTab('inventory')} icon={<Package size={24}/>} label="Stock" />
        <div className="relative -top-6">
          <button 
            onClick={() => setActiveTab('add-new')}
            className={`w-14 h-14 rounded-full flex items-center justify-center shadow-lg transition-transform active:scale-90 ${activeTab === 'add-new' ? 'bg-blue-600 text-white shadow-blue-300' : 'bg-white text-blue-600 border-2 border-blue-600'}`}
          >
            <Plus size={32} />
          </button>
        </div>
        <MobileNavItem active={activeTab === 'settings'} onClick={() => setActiveTab('settings')} icon={<Settings size={24}/>} label="Settings" />
        <div className="w-12 h-12 flex flex-col items-center justify-center opacity-0 pointer-events-none" />
      </nav>
    </div>
  );
};

