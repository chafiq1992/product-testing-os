import React, { useState, useEffect, useRef, useMemo } from 'react';
import { 
  LayoutDashboard, 
  PlusCircle, 
  Package, 
  Camera, 
  Settings, 
  Trash2, 
  Plus, 
  Check, 
  Loader2, 
  TrendingUp, 
  Box, 
  DollarSign, 
  Tag as TagIcon,
  RefreshCw,
  Image as ImageIcon,
  Filter,
  ChevronDown,
  Calendar,
  Clock,
  Layers,
  X
} from 'lucide-react';
